        "name": "f11"
      },
      {
        "seq": "\u001b[24~",
        "name": "f12"
      }
    ],
    "ctrl_pattern": {
      "prefix": "ctrl-",
      "base_char": "a",
      "base_code": 1
    },
    "signals": [
      {
        "name": "SIGINT",
        "number": 2,
        "event": "quit"
      },
      {
        "name": "SIGTERM",
        "number": 15,
        "event": "quit"
      },
      {
        "name": "SIGWINCH",
        "number": 28,
        "event": "resize"
      }
    ],
    "terminal_sequences": [
      {
        "seq": "\u001b[I",
        "event": "focus"
      },
      {
        "seq": "\u001b[O",
        "event": "defocus"
      }
    ],
    "mouse": {
      "prefix": "\u001b[\u003c",
      "press_suffix": "M",
      "release_suffix": "m",
      "enable_button": "\u001b[?1002h\u001b[?1006h",
      "enable_motion": "\u001b[?1003h\u001b[?1006h",
      "disable_button": "\u001b[?1002l\u001b[?1006l",
      "disable_motion": "\u001b[?1003l\u001b[?1006l",
      "btn_button_mask": 3,
      "btn_shift_mask": 4,
      "btn_meta_mask": 8,
      "btn_ctrl_mask": 16,
      "btn_motion_flag": 32,
      "btn_scroll_flag": 64,
      "btn_no_button": 3
    },
    "tokenizer": {
      "rules": [
        {
          "name": "sgr_mouse",
          "match": "starts_with",
          "prefix": "\u001b[\u003c",
          "scan_until": "Mm",
          "emit": "mouse"
        },
        {
          "name": "csi_sequence",
          "match": "starts_with",
          "prefix": "\u001b[",
          "scan_class": "alpha_tilde",
          "emit": "key"
        },
        {
          "name": "bare_escape",
          "match": "starts_with",
          "prefix": "\u001b",
          "emit": "key"
        },
        {
          "name": "utf8_multibyte",
          "match": "utf8_lead",
          "emit": "key"
        },
        {
          "name": "any_char",
          "match": "any",
          "emit": "key"
        }
      ]
    }
  }
}
