      {
        "seq": "\u001bOH",
        "name": "home"
      },
      {
        "seq": "\u001b[F",
        "name": "end"
      },
      {
        "seq": "\u001b[4~",
        "name": "end"
      },
      {
        "seq": "\u001b[8~",
        "name": "end"
      },
      {
        "seq": "\u001bOF",
        "name": "end"
      },
      {
        "seq": "\u001b[1;5C",
