{
  "$schema": "../../../wayreel/reel.schema.json",
  "mode": "tui",
  "build": ["zig", "build", "-Doptimize=ReleaseSmall"],
  "binary": "zig-out/bin/emojig",
  "bitrate": "2M",
  "fps": 30,
  "scene_width": 850,
  "scene_height": 480,
  "theme": "light",
  "font_size": 12,
  "output": "website/emojig-tui-light.webm",
  "title": "Any Terminal",
  "prompt": [
    { "text": "➜", "color": "green" },
    { "text": "  " },
    { "text": "~", "color": "cyan" },
    { "text": " " }
  ],
  "shell_init": ["source $(pwd)/src/shell/emojig.zsh"],
  "env": [
    "EMOJIG_TERMINAL=foot",
    "EMOJIG_GUI_FONT_SIZE=12",
    "EMOJIG_THEME=light"
  ],
  "script": [
    { "type": "echo Hello TUI ", "desc": "simple echo - no CR yet" },
    { "type": "<C-e>", "desc": "open emojig", "show_keys": true },
    { "pause": "1s" },
    { "type": "car", "desc": "search for 'car'", "speed": 0.4 },
    { "pause": "1s" },
    { "type": "<bs><bs><bs>", "desc": "delete search" },
    { "type": "cat", "desc": "search for cat", "speed": 0.4 },
    { "pause": "1s" },
    { "type": "<cr>", "desc": "select cat", "show_keys": true },
    { "pause": "1s" },
    { "type": "<cr>", "desc": "confirm echo" },
    { "pause": "1s" }
  ]
}
