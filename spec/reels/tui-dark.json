{
  "$schema": "../../../wayreel/reel.schema.json",
  "mode": "tui",
  "build": ["zig", "build", "-Doptimize=ReleaseSmall"],
  "binary": "zig-out/bin/emojig",
  "bitrate": "2M",
  "fps": 30,
  "scene_width": 850,
  "scene_height": 480,
  "theme": "dark",
  "font_size": 12,
  "output": "website/emojig-tui-dark.webm",
  "title": "emojig demo",
  "prompt": [
    { "text": "➜", "color": "green" },
    { "text": "  " },
    { "text": "~", "color": "cyan" },
    { "text": " " }
  ],
  "shell_init": ["source $(pwd)/src/shell/emojig.sh"],
  "env": ["EMOJIG_THEME=light"],
  "pause": "1s",
  "script": [
    { "type": "echo Hello TUI ", "desc": "echo start", "pause": 0 },
    { "type": "<C-e>", "desc": "open emojig", "show_keys": true },
    { "type": "car", "desc": "search for 'car'", "speed": 0.4 },
    { "type": "<bs><bs><bs>", "desc": "delete search", "speed": 0.4, "pause": 0 },
    { "type": "cat", "desc": "search for cat", "speed": 0.4 },
    { "type": "<cr>", "desc": "select cat", "show_keys": true },
    { "type": "<cr>", "desc": "confirm echo" }
  ]
}
