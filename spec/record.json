{
  "build": ["zig", "build", "-Doptimize=ReleaseSmall"],
  "binary": "zig-out/bin/emojig",
  "bitrate": "2M",
  "fps": 30,
  "tui_font_size": 12,
  "gui_font_size": 12,
  "scene_width": 850,
  "scene_height": 480,
  "tui_output": "website/emojig-tui-dark.webm",
  "tui_prompt": [
    { "text": "➜", "color": "green" },
    { "text": "  " },
    { "text": "~", "color": "cyan" },
    { "text": " " }
  ],
  "tui_title": "Any Terminal",
  "tui_shell_init": ["source $(pwd)/src/shell/emojig.zsh"],
  "tui_env": ["EMOJIG_TERMINAL=foot", "EMOJIG_GUI_FONT_SIZE=12"],
  "tui_script": [
    { "type": "echo Hello TUI ", "desc": "simple echo - no CR yet" },
    { "type": "<C-e>", "desc": "open emojig", "show_keys": true },
    { "pause": "1s" },
    { "type": "car", "desc": "search for 'car'" },
    { "pause": "1s" },
    { "type": "<bs><bs><bs>", "desc": "delete search" },
    { "type": "cat", "desc": "search for cat" },
    { "pause": "1s" },
    { "type": "<cr>", "desc": "select cat", "show_keys": true },
    { "pause": "1s" },
    { "type": "<cr>", "desc": "confirm echo" },
    { "pause": "1s" }
  ],
  "gui_output": "website/emojig-gui-light.webm",
  "gui_app_cmd": ["gedit", "$demo_file"],
  "gui_app_id": "gedit",
  "gui_app_width": 530,
  "gui_app_height": 400,
  "gui_app_env": ["GTK_THEME=Adwaita:light"],
  "gui_app_script": [
    { "type": "Hello GUI ", "desc": "pre-emoji text" },
    { "type": "<C-A-space>", "desc": "fake gui hotkey", "show_keys": true },
    { "next": "gui_picker_script" },
    { "type": "<S-ins>", "desc": "(fake) paste hotkey", "show_keys": true },
    { "type": "🖥️", "desc": "(fake) paste" },
    { "pause": "1s" }
  ],
  "gui_picker_args": ["--gui", "--theme", "light"],
  "gui_picker_app_id": "emojig-picker",
  "gui_picker_env": ["EMOJIG_TERMINAL=foot", "EMOJIG_GUI_FONT_SIZE=12"],
  "gui_picker_script": [
    { "type": "compu", "desc": "search query" },
    { "pause": "1s" },
    { "type": " desk", "desc": "search query" },
    { "pause": "1s" },
    { "type": "<cr>", "desc": "select first result", "show_keys": true }
  ]
}
