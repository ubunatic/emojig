    },
    {
      "id": "show_all_categories",
      "type": "boolean",
      "label": "show all categories",
      "default": "true"
    },
    {
      "id": "ambiguous_chars",
      "type": "choice",
      "label": "ambiguous chars",
      "choices": ["wide", "narrow"],
      "default": "narrow"
    }
  ]
}
