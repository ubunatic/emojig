{
  "description": "Interactive settings configuration options for the picker.",
  "title": "⚙️ emojig settings",
  "options": [
    {
      "id": "shell_integration",
      "type": "boolean",
      "label": "shell integration",
      "default": "false"
    },
    {
      "id": "shell_key_binding",
      "type": "choice",
      "label": "shell key binding",
      "choices": ["C-e", "C-.", "C-A-<space>", "none"],
